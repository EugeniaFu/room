generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  INE
  CURP
  COMPROBANTE_DOMICILIO
  FOTO
  TELEFONO
  CREDENCIAL_ESTUDIANTE
  ACTA_NACIMIENTO
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ConnectionRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ListingStatus {
  ACTIVE
  RENTED
  HIDDEN
  DELETED
}

enum ListingType {
  ROOM
  APARTMENT
  HOUSE
  STUDIO
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SleepSchedule {
  EARLY_SLEEPER
  NIGHT_OWL
  FLEXIBLE
}

enum RentalMode {
  SHARED
  NEW_ONLY
}

enum RoomOwnership {
  PRIVATE
  SHARED
}

enum Amenity {
  LIVING_ROOM
  KITCHEN
  BATHROOM
  YARD
  TERRACE
  LAUNDRY_AREA
  PARKING
}

enum ListingReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TenancyStatus {
  INTERESTED
  ACTIVE
  ENDED
}

enum ReviewCategory {
  GENERAL
  PUNTUALIDAD_PAGO
  LIMPIEZA
  CONVIVENCIA
}

enum VerificationCodeType {
  EMAIL_CONFIRMATION
  PASSWORD_RESET
}

//////////////////////
// MODELS
//////////////////////

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String

  isActive  Boolean  @default(true)

  isOnline  Boolean  @default(false)
  lastSeen  DateTime?

  createdAt DateTime @default(now())

  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?

  //////////////////////
  // RELACIONES
  //////////////////////

  profile  Profile?
  roles    UserRole[]

  listings Listing[]

  messages Message[]

  documents Document[]

  reviewsGiven    Review[] @relation("reviewsGiven")
  reviewsReceived Review[] @relation("reviewsReceived")

  matchesAsUser1 Match[] @relation("MatchUser1")
  matchesAsUser2 Match[] @relation("MatchUser2")

  verificationReviews VerificationReview[] @relation("UserVerification")
  adminReviews        VerificationReview[] @relation("AdminVerification")

  listingRoommates ListingRoommate[]

  preferences Preference?

  conversationParticipants ConversationParticipant[]

  sentRequests     ConnectionRequest[] @relation("RequestSender")
  receivedRequests ConnectionRequest[] @relation("RequestReceiver")

  blockedUsers   BlockedUser[] @relation("Blocker")
  blockedByUsers BlockedUser[] @relation("Blocked")

  reportsMade     Report[] @relation("Reporter")
  reportsReceived Report[] @relation("Reported")

  favoriteListings FavoriteListing[]

  reviewedListings Listing[] @relation("ListingReviewedBy")

  contractsAsHost   RentalAgreement[] @relation("ContractHost")
  contractsAsRoomie RentalAgreement[] @relation("ContractRoomie")

  verificationCodes VerificationCode[]
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  users UserRole[]
}

model UserRole {
  userId String
  roleId Int

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Profile {
  id         String  @id @default(uuid())
  userId     String  @unique

  name       String
  bio        String?

  age        Int?

  gender     Gender?

  university String?

  avatarUrl  String?

  occupation String?

  city       String?

  instagram  String?

  smokes Boolean?

  drinks Boolean?

  pets Boolean?

  cleanlinessLevel Int?

  noiseLevel Int?

  sleepSchedule SleepSchedule?

  personalityType String?

  languages String[]

  interests String[]

  lookingFor String?

  user User @relation(fields: [userId], references: [id])
}

//////////////////////
// VERIFICACIÓN
//////////////////////

model Document {
  id        String         @id @default(uuid())

  userId    String

  type      DocumentType

  url       String

  status    DocumentStatus @default(PENDING)

  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model VerificationCode {
  id String @id @default(uuid())

  userId String

  code String

  type VerificationCodeType

  expiresAt DateTime

  usedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

model VerificationReview {
  id        String             @id @default(uuid())

  userId    String

  adminId   String

  status    VerificationStatus

  notes     String?

  createdAt DateTime           @default(now())

  user  User @relation("UserVerification", fields: [userId], references: [id])

  admin User @relation("AdminVerification", fields: [adminId], references: [id])
}

//////////////////////
// LISTINGS
//////////////////////

model Listing {
  id          String   @id @default(uuid())

  ownerId     String

  title       String

  description String

  price       Float

  type        String

  status      ListingStatus @default(ACTIVE)

  coverImage  String?

  city        String?

  availableFrom DateTime?

  deposit Float?

  roomType String?

  bathroomType String?

  furnished Boolean @default(false)

  utilitiesIncluded Boolean @default(false)

  wifi Boolean @default(false)

  parking Boolean @default(false)

  laundry Boolean @default(false)

  maxRoommates Int?

  currentRoommates Int @default(0)

  compatibilityScore Float?

  createdAt DateTime @default(now())

  rentalMode        RentalMode?
  bedroomCount      Int?
  roomOwnership     RoomOwnership?
  floor             Int?
  amenities         Amenity[]

  hasPetsNow      Boolean @default(false)
  petsAllowed     Boolean @default(false)
  allowedPetTypes String[]
  privateAreas    String[]
  sharedAreas     String[]

  includedServices String[]
  extraServices    String[]
  neighborhood     String?
  nearbyLandmark   String?
  minStayMonths    Int?

  seekingGender        Gender?
  wheelchairAccessible Boolean @default(false)
  hostDescription      String?
  seekingRoommateBio   String?
  houseRules           String[]

  reviewStatus ListingReviewStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?

  owner User @relation(fields: [ownerId], references: [id])

  reviewedBy User? @relation("ListingReviewedBy", fields: [reviewedById], references: [id])

  location Location?

  images ListingImage[]

  roommates ListingRoommate[]

  favorites FavoriteListing[]

  contracts RentalAgreement[]

  connectionRequests ConnectionRequest[]

  conversations Conversation[]

  @@index([ownerId])
}

model Location {
  id        String @id @default(uuid())

  listingId String @unique

  country   String

  state     String

  city      String

  latitude  Float

  longitude Float

  listing Listing @relation(fields: [listingId], references: [id])
}

model ListingRoommate {
  id String @id @default(uuid())

  listingId String

  userId String

  status TenancyStatus @default(INTERESTED)

  matchedAt DateTime?

  endedAt DateTime?

  listing Listing @relation(fields: [listingId], references: [id])

  user User @relation(fields: [userId], references: [id])

  reviews Review[]
}

model ListingImage {
  id String @id @default(uuid())

  listingId String

  url String

  order Int @default(0)

  listing Listing @relation(fields: [listingId], references: [id])
}

//////////////////////
// MATCHING
//////////////////////

model Preference {
  id String @id @default(uuid())

  userId String @unique

  smoking Boolean

  pets Boolean

  sleepSchedule SleepSchedule

  cleanlinessLevel Int

  budgetMin Float

  budgetMax Float

  preferredGender Gender?

  maxAge Int?

  minAge Int?

  acceptsPets Boolean?

  acceptsSmoking Boolean?

  preferredCity String?

  preferredUniversity String?

  user User @relation(fields: [userId], references: [id])
}

model Match {
  id String @id @default(uuid())

  user1Id String

  user2Id String

  score Float

  compatibilityScore Float?

  status MatchStatus @default(PENDING)

  matchedAt DateTime?

  isHidden Boolean @default(false)

  createdAt DateTime @default(now())

  user1 User @relation("MatchUser1", fields: [user1Id], references: [id])

  user2 User @relation("MatchUser2", fields: [user2Id], references: [id])

  @@unique([user1Id, user2Id])

  @@index([user1Id])

  @@index([user2Id])
}

//////////////////////
// CHAT
//////////////////////

model Conversation {
  id String @id @default(uuid())

  lastMessage String?

  lastMessageAt DateTime?

  // publicación sobre la que trata esta conversación (opcional,
  // nula para conversaciones que vienen del descubrimiento persona-a-persona)
  listingId String?

  createdAt DateTime @default(now())

 updatedAt DateTime @default(now()) @updatedAt

  participants ConversationParticipant[]

  messages Message[]

  listing Listing? @relation(fields: [listingId], references: [id])
}

model ConversationParticipant {
  conversationId String

  userId String

  conversation Conversation @relation(fields: [conversationId], references: [id])

  user User @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])

  @@index([userId])
}

model Message {
  id String @id @default(uuid())

  conversationId String

  senderId String

  content String

  type String @default("text")

  attachmentUrl String?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  sender User @relation(fields: [senderId], references: [id])

  @@index([conversationId])

  @@index([senderId])
}

//////////////////////
// REVIEWS
//////////////////////

model Review {
  id String @id @default(uuid())

  reviewerId String

  reviewedId String

  rating Int

  comment String

  isVisible Boolean @default(true)

  createdAt DateTime @default(now())

  matchId String?

  category ReviewCategory @default(GENERAL)

  reviewer User @relation("reviewsGiven", fields: [reviewerId], references: [id])

  reviewed User @relation("reviewsReceived", fields: [reviewedId], references: [id])

  match ListingRoommate? @relation(fields: [matchId], references: [id])
}

//////////////////////
// CONEXIONES
//////////////////////

model ConnectionRequest {
  id String @id @default(uuid())

  senderId String

  receiverId String

  // publicación por la que se contactó al anfitrión;
  // null cuando viene del descubrimiento persona-a-persona (swipe)
  listingId String?

  status ConnectionRequestStatus @default(PENDING)

  createdAt DateTime @default(now())

 updatedAt DateTime @default(now()) @updatedAt

  sender User @relation("RequestSender", fields: [senderId], references: [id])

  receiver User @relation("RequestReceiver", fields: [receiverId], references: [id])

  listing Listing? @relation(fields: [listingId], references: [id])

  @@unique([senderId, receiverId, listingId])
}

//////////////////////
// BLOQUEOS
//////////////////////

model BlockedUser {
  id String @id @default(uuid())

  blockerId String

  blockedId String

  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id])

  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

//////////////////////
// REPORTES
//////////////////////

model Report {
  id String @id @default(uuid())

  reporterId String

  reportedUserId String

  reason String

  details String?

  createdAt DateTime @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id])

  reportedUser User @relation("Reported", fields: [reportedUserId], references: [id])
}

//////////////////////
// FAVORITOS
//////////////////////

model FavoriteListing {
  id String @id @default(uuid())

  userId String

  listingId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  listing Listing @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

//////////////////////
// CONTRATO BASE
//////////////////////

model RentalAgreement {
  id String @id @default(uuid())

  listingId String

  hostId String

  roomieId String

  content String

  isLocked Boolean @default(false)

  startedAt DateTime @default(now())

  endedAt DateTime?

  listing Listing @relation(fields: [listingId], references: [id])

  host User @relation("ContractHost", fields: [hostId], references: [id])

  roomie User @relation("ContractRoomie", fields: [roomieId], references: [id])

  @@index([listingId])
}

model SkippedProfile {

  id String @id @default(uuid())

  userId String
  skippedUserId String

  createdAt DateTime @default(now())

  @@unique([userId, skippedUserId])
}